# ============================================================
# Coter Pro — Variables de Entorno
# Copia este archivo a .env y configura los valores
# ============================================================

# Entorno: development | production | test
NODE_ENV=development

# Puerto del servidor
PORT=3000

# ─── BASE DE DATOS ───────────────────────────────────────────
# PostgreSQL connection string
# Desarrollo local: postgresql://postgres:password@localhost:5432/coter
# Producción: La URL que te dé tu proveedor (Railway, Supabase, Neon, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coter

# Pool de conexiones
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── SEGURIDAD ───────────────────────────────────────────────
# JWT Secret: genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZAR_CON_SECRETO_DE_64_BYTES
JWT_EXPIRES_IN=30d

# Clave de encriptación AES-256: exactamente 64 caracteres hexadecimales
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REEMPLAZAR_CON_64_HEX_CHARS

# ─── CORS ────────────────────────────────────────────────────
# Orígenes permitidos (separados por coma)
# Desarrollo: http://localhost:3000,http://localhost:8080
# Producción: https://coter.app,https://app.coter.app
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# ─── EMAIL (Recuperación de contraseña) ──────────────────────
# Opcional en desarrollo; requerido en producción
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_123456789
SMTP_FROM=noreply@coter.app

# URL pública de la aplicación (para links en emails)
APP_URL=http://localhost:3000

# ─── RATE LIMITING ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=debug
